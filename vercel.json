{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/chess/:username",
      "destination": "/frontend/api/chess.js?username=:username"
    },
    {
      "source": "/api/chess",
      "destination": "/frontend/api/chess.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1",
      "check": true
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
